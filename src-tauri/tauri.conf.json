{
  "productName": "WorldEditor",
  "version": "0.3.1",
  "identifier": "com.worldeditor",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../frontend && yarn dev:tauri",
    "beforeBuildCommand": "cd ../frontend && yarn build"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src ipc: http://ipc.localhost 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "dialog": null,
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/lin51kevin/worldeditor/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ5ODgxNzVGQzA2MzlFNzAKUldSd25tUEFYeGVJMmRiM3lxa3lHZGhJT3hEYi9ZbWRxaVdDRVV4eWNxVmNqMmNuTTFvd0N4cEMK"
    }
  }
}