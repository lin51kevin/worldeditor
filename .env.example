# WorldEditor Next — Environment Variables
# Copy this file to .env and fill in the values.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-use-strong-random-password
POSTGRES_DB=worldeditor

# Server
DATABASE_URL=postgres://postgres:changeme@localhost:5432/worldeditor
JWT_SECRET=changeme-must-be-at-least-32-characters-long-use-random
ADMIN_USER=admin
ADMIN_PASS=changeme-use-strong-password
RUST_LOG=info

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
